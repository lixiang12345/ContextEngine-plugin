# Required runtime store: PostgreSQL with the pgvector extension.
# Local default after `npm run db:up`.
CONTEXTENGINE_DATABASE_URL=postgresql://contextengine:contextengine@127.0.0.1:54329/contextengine

# HTTP service (required for `contextengine-http` / `contextengine http`).
# Keep this secret outside source control. HTTP refuses to start without it
# unless CONTEXTENGINE_HTTP_ALLOW_UNAUTHENTICATED=1 is explicitly set.
CONTEXTENGINE_HTTP_API_KEY=
# Multi-principal deployments use a JSON array. When set, newly created
# workspaces are private to their creator and can be shared with reader/writer/
# owner permissions. The legacy single key remains an all-workspace operator.
# CONTEXTENGINE_HTTP_API_KEYS=[{"principal_id":"alice","token":"replace-me"},{"principal_id":"ops","token":"replace-me-too","role":"operator"}]
# Docker Compose publishes the HTTP service on port 8790 by default.
# It binds to loopback by default; use 0.0.0.0 only for a trusted remote deployment.
# CONTEXTENGINE_DOCKER_HTTP_BIND_HOST=127.0.0.1
# CONTEXTENGINE_DOCKER_HTTP_PORT=8790
# CONTEXTENGINE_HTTP_HOST=127.0.0.1
# CONTEXTENGINE_HTTP_PORT=8787
# CONTEXTENGINE_HTTP_MAX_BLOB_BYTES=2097152
# CONTEXTENGINE_HTTP_ALLOW_LOCAL_WORKSPACES=0
# CONTEXTENGINE_LOCAL_ROOT_ALLOWLIST=/srv/repos:/Users/me/Code
# Remote MCP sessions are bounded to avoid abandoned clients retaining memory.
# Idle sessions are closed after 30 minutes by default; the service accepts up
# to 128 live sessions per process.
# CONTEXTENGINE_MCP_SESSION_IDLE_TTL_MS=1800000
# CONTEXTENGINE_MCP_MAX_SESSIONS=128
# Runtime model URLs cannot target private/local networks unless the endpoint
# was configured at startup or this trusted-deployment override is enabled.
# CONTEXTENGINE_HTTP_ALLOW_PRIVATE_MODEL_URLS=0

# Optional read-only GitHub connector. Public repositories do not need a token;
# private repositories require a fine-grained token with Contents: read or a
# GitHub App installation token supplied by an external secret manager.
# CONTEXTENGINE_GITHUB_TOKEN=
# CONTEXTENGINE_GITHUB_API_BASE_URL=https://api.github.com
# CONTEXTENGINE_GITHUB_TIMEOUT_MS=30000

# Default model-service profile: an OpenAI-compatible Qwen endpoint exposing
# both POST /v1/embeddings and POST /v1/rerank. Without credentials,
# ContextEngine continues to run in BM25-only mode.
CONTEXTENGINE_EMBEDDING_API_KEY=
CONTEXTENGINE_EMBEDDING_BASE_URL=
CONTEXTENGINE_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
CONTEXTENGINE_EMBEDDING_DIMENSIONS=1024
# A root origin is also accepted and normalized to /v1.
# CONTEXTENGINE_API_TIMEOUT_MS=120000
# CONTEXTENGINE_API_RETRIES=2
# Retrieval model calls have a short independent budget and fall back to BM25
# when unavailable. Increase only when the model service is known to be local.
# CONTEXTENGINE_SEARCH_SEMANTIC_TIMEOUT_MS=2000
# CONTEXTENGINE_SEARCH_RERANK_TIMEOUT_MS=2000
# CONTEXTENGINE_SEARCH_BREAKER_FAILURE_THRESHOLD=3
# CONTEXTENGINE_SEARCH_BREAKER_COOLDOWN_MS=30000
# Retain retired/failed index generations for one hour so stale readers can
# refresh before old PostgreSQL namespaces are reclaimed.
# CONTEXTENGINE_GENERATION_RETENTION_MS=3600000
# Send input_type=document/query to servers that expose the Qwen3 v2 schema.
# Remove this setting for generic OpenAI-compatible gateways.
CONTEXTENGINE_EMBEDDING_INPUT_TYPE=1

# Neural rerank is enabled by default for the combined Qwen endpoint and reuses
# CONTEXTENGINE_EMBEDDING_API_KEY when a separate key is not provided.
CONTEXTENGINE_NEURAL_RERANK=1
CONTEXTENGINE_RERANK_MODEL=Qwen/Qwen3-Reranker-0.6B
# CONTEXTENGINE_RERANK_BASE_URL=
# CONTEXTENGINE_RERANK_API_KEY=
CONTEXTENGINE_RERANK_INSTRUCTION=Given a programming task or natural language question about a codebase, retrieve the most relevant source code implementation.

# Alternative short names also work:
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_EMBEDDING_MODEL=
