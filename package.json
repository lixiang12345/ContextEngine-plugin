{
  "name": "contextengine-plugin",
  "version": "0.4.0",
  "description": "Augment-class portable Context Engine — multi-signal FTS/symbol/semantic retrieval, graph expand, MMR pack, MCP for coding agents.",
  "type": "module",
  "bin": {
    "contextengine": "./dist/cli.js",
    "contextengine-mcp": "./dist/mcp-server.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "COMPARISON.md",
    "examples"
  ],
  "scripts": {
    "build": "tsc && node scripts/ensure-bins.mjs",
    "dev": "tsc --watch",
    "cli": "node --import tsx src/cli.ts",
    "mcp": "node --import tsx src/mcp-server.ts",
    "test": "node --import tsx --test test/**/*.test.ts",
    "eval:self": "npm run build && node dist/cli.js eval --self --reindex",
    "eval:express": "npm run build && node scripts/practice-eval.mjs --root ${EXPRESS_ROOT:-/tmp/ce-midsize-eval/express4} --cases examples/eval.express.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "context-engine",
    "mcp",
    "code-search",
    "rag",
    "ai-coding",
    "semantic-search",
    "bm25",
    "claude-code",
    "cursor"
  ],
  "author": "ContextEngine contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lixiang12345/ContextEngine-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/lixiang12345/ContextEngine-plugin/issues"
  },
  "homepage": "https://github.com/lixiang12345/ContextEngine-plugin#readme",
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^13.1.0",
    "ignore": "^7.0.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
